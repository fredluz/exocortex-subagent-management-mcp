{
  "name": "exocortex-subagent-management-mcp",
  "version": "0.1.0",
  "description": "MCP server for exocortex subagent management via tmux",
  "packageManager": "bun@1.3.6",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "exocortex-subagent-management-mcp": "dist/index.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "release-check": "bash ./scripts/release-gate.sh",
